{
  "name": "consonant-specs-plugin",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/consonant-specs-plugin/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "node apps/consonant-specs-plugin/esbuild.config.mjs",
        "cwd": "{workspaceRoot}"
      }
    },
    "watch": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node apps/consonant-specs-plugin/esbuild.config.mjs --watch",
        "cwd": "{workspaceRoot}"
      }
    },
    "package": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "cd apps/consonant-specs-plugin/dist && zip -r ../../../dist/apps/consonant-specs-plugin.zip .",
        "cwd": "{workspaceRoot}"
      }
    }
  },
  "tags": ["scope:figma", "type:app"]
}
