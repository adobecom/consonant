{
  "name": "ElasticCard",
  "slug": "elastic-card",
  "cssClass": "c-elastic-card",
  "storybookId": "elastic-card",
  "description": "Navigation card with three states: resting (compact, on-light header), expanded (full-bleed media, on-dark overlay), and mobile (stacked layout with CTA puck). Composes ProductLockup and Media.",
  "composedOf": ["ProductLockup", "Media"],
  "variants": {
    "state": ["resting", "expanded", "mobile"],
    "mediaAspect": ["3:4", "4:3", "16:9", "1:1"]
  },
  "props": [
    { "name": "label", "type": "string", "defaultValue": "\"Creativity and design\"", "description": "Product category label passed to ProductLockup" },
    { "name": "app", "type": "string", "defaultValue": "\"experience-cloud\"", "description": "App slug passed to ProductLockup → AppIcon" },
    { "name": "product", "type": "object", "description": "ProductLockup prop overrides. Merged with label/app defaults." },
    { "name": "title", "type": "string", "defaultValue": "\"Card title\"" },
    { "name": "body", "type": "string" },
    { "name": "state", "type": "string", "defaultValue": "\"resting\"", "enum": ["resting", "expanded", "mobile"] },
    { "name": "mediaSrc", "type": "string" },
    { "name": "mediaAlt", "type": "string", "defaultValue": "\"\"" },
    { "name": "mediaTemplate", "type": "TemplateResult", "description": "Custom media — bypasses Media component" },
    { "name": "mediaAspect", "type": "string", "defaultValue": "\"3:4\"", "enum": ["3:4", "4:3", "16:9", "1:1"] },
    { "name": "mediaOverlay", "type": "boolean", "defaultValue": "true" },
    { "name": "bodyTemplate", "type": "TemplateResult", "description": "Replaces default title+body+action rendering" },
    { "name": "children", "type": "TemplateResult" },
    { "name": "showCaret", "type": "boolean" },
    { "name": "actionTemplate", "type": "TemplateResult" },
    { "name": "actionLabel", "type": "string" },
    { "name": "href", "type": "string", "description": "Makes root element an <a> tag" },
    { "name": "ariaLabel", "type": "string" },
    { "name": "onClick", "type": "function" },
    { "name": "tag", "type": "string", "description": "Force a specific root element tag" }
  ],
  "tokenBindings": {
    "background-color:resting": "--s2a-color-background-default",
    "background-color:expanded": "--s2a-color-background-knockout",
    "color:resting:header": "--s2a-color-content-default",
    "color:expanded:header": "--s2a-color-content-knockout",
    "border-radius": "--s2a-border-radius-lg",
    "padding": "--s2a-spacing-md"
  },
  "a11y": {
    "wcag": ["1.4.3", "2.1.1", "2.4.4", "2.4.7"],
    "keyboard": [
      { "key": "Enter", "action": "Activates card link/button" },
      { "key": "Tab", "action": "Moves focus into/out of card" }
    ],
    "notes": [
      "Root element is <a>, <button>, or <div> depending on href/onClick/tag props.",
      "When rendered as <div> it gets role='presentation' — ensure interactive children have their own accessible names.",
      "Media images should have meaningful alt text when the image provides content not described elsewhere."
    ]
  }
}
