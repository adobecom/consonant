{
  "name": "Media",
  "slug": "media",
  "cssClass": "c-media",
  "storybookId": "media",
  "description": "Constrained image or video with aspect ratio, size, object-fit, and optional gradient overlay. Used inside ElasticCard and MediaCard.",
  "variants": {
    "aspectRatio": ["16:9", "4:3", "1:1", "3:2", "3:4", "21:9"],
    "size": ["xs", "sm", "md", "lg", "xl", "full"],
    "objectFit": ["cover", "contain", "fill", "none", "scale-down"],
    "objectPosition": ["center", "top", "bottom", "left", "right", "top-left", "top-right", "bottom-left", "bottom-right"],
    "type": ["image", "video"]
  },
  "props": [
    { "name": "src", "type": "string", "description": "Image or video URL" },
    { "name": "alt", "type": "string", "defaultValue": "\"\"", "description": "Alt text for images. Empty string for decorative images." },
    { "name": "aspectRatio", "type": "string", "defaultValue": "\"3:4\"", "enum": ["16:9", "4:3", "1:1", "3:2", "3:4", "21:9"] },
    { "name": "size", "type": "string", "defaultValue": "\"full\"", "enum": ["xs", "sm", "md", "lg", "xl", "full"] },
    { "name": "objectFit", "type": "string", "defaultValue": "\"cover\"", "enum": ["cover", "contain", "fill", "none", "scale-down"] },
    { "name": "objectPosition", "type": "string", "defaultValue": "\"center\"" },
    { "name": "type", "type": "string", "defaultValue": "\"image\"", "enum": ["image", "video"] },
    { "name": "lazy", "type": "boolean", "defaultValue": "true" },
    { "name": "poster", "type": "string", "description": "Poster image URL for video type" },
    { "name": "autoplay", "type": "boolean", "defaultValue": "false" },
    { "name": "muted", "type": "boolean", "defaultValue": "true" },
    { "name": "loop", "type": "boolean", "defaultValue": "true" },
    { "name": "controls", "type": "boolean", "defaultValue": "false" },
    { "name": "playsinline", "type": "boolean", "defaultValue": "true" },
    { "name": "overlay", "type": "boolean | TemplateResult", "description": "Gradient overlay. false = none. Defaults to bottom gradient." },
    { "name": "sources", "type": "Array<{src: string, type: string}>", "description": "Video <source> entries" },
    { "name": "mediaTemplate", "type": "TemplateResult", "description": "Fully custom media node — bypasses image/video rendering" }
  ],
  "tokenBindings": {
    "border-radius": "--s2a-border-radius-lg"
  },
  "a11y": {
    "wcag": ["1.1.1", "1.2.2", "1.4.3"],
    "notes": [
      "Provide meaningful alt text for content images. Use alt='' for decorative media.",
      "Autoplay videos must be muted. Do not autoplay video with audio.",
      "If controls=false, ensure media is not the sole source of information."
    ]
  }
}
