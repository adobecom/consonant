{
  "name": "IconButton",
  "slug": "icon-button",
  "figmaNodeId": "2142-53869",
  "cssClass": "c-icon-button",
  "storybookId": "icon-button",
  "description": "Icon-only action trigger. Requires aria-label. Supports solid, outlined, and transparent backgrounds in on-light and on-dark contexts.",
  "variants": {
    "background": ["solid", "outlined", "transparent"],
    "context": ["on-light", "on-dark"],
    "size": ["md", "lg"],
    "state": ["default", "hover", "active", "focus", "disabled"]
  },
  "props": [
    { "name": "ariaLabel", "type": "string", "required": true, "description": "Accessible label — required since there is no visible text" },
    { "name": "icon", "type": "string | TemplateResult", "defaultValue": "\"pause\"", "description": "Phosphor icon name (e.g. 'play') or a Lit TemplateResult. 'pause' renders the built-in SVG." },
    { "name": "background", "type": "string", "defaultValue": "\"solid\"", "enum": ["solid", "outlined", "transparent"] },
    { "name": "context", "type": "string", "enum": ["on-light", "on-dark"], "description": "Surface context. Inferred from tone if omitted." },
    { "name": "size", "type": "string", "defaultValue": "\"lg\"", "enum": ["md", "lg"] },
    { "name": "state", "type": "string", "defaultValue": "\"default\"", "enum": ["default", "hover", "active", "focus", "disabled"] },
    { "name": "tone", "type": "string", "enum": ["default", "knockout"], "deprecated": true, "deprecatedReason": "Use context instead. knockout → on-dark" },
    { "name": "onClick", "type": "function" }
  ],
  "tokenBindings": {
    "background-color:solid+on-light+default": "--s2a-color-background-knockout",
    "background-color:solid+on-dark+default": "--s2a-color-background-default",
    "color:solid+on-light": "--s2a-color-content-knockout",
    "color:solid+on-dark": "--s2a-color-content-default",
    "opacity:disabled": "--s2a-opacity-disabled",
    "border-radius": "--s2a-border-radius-round",
    "border-width": "--s2a-border-width-sm"
  },
  "a11y": {
    "role": "button",
    "requiredAriaAttrs": ["aria-label"],
    "wcag": ["1.1.1", "1.4.3", "2.1.1", "2.4.7"],
    "keyboard": [
      { "key": "Enter", "action": "Activates the button" },
      { "key": "Space", "action": "Activates the button" }
    ],
    "notes": [
      "aria-label is required — there is no visible text label.",
      "Icon SVG content carries aria-hidden='true' — the button label comes only from aria-label."
    ]
  }
}
